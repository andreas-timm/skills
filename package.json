{
    "name": "@andreas-timm/skills",
    "version": "0.1.4",
    "description": "Local-first skill registry and approval CLI for agent skills",
    "license": "BSD-2-Clause",
    "author": {
        "name": "Andreas Timm",
        "email": "info@andreas-timm.dev"
    },
    "homepage": "https://github.com/andreas-timm/skills#readme",
    "bugs": {
        "url": "https://github.com/andreas-timm/skills/issues"
    },
    "keywords": [
        "agent",
        "bun",
        "cli",
        "skills",
        "typescript"
    ],
    "type": "module",
    "files": [
        "dist",
        "global.toml",
        "LICENSE",
        "README.md",
        "src/**/*.ts",
        "!src/**/*.spec.ts",
        "!src/**/tests/**"
    ],
    "bin": {
        "skills": "dist/cli.js"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/andreas-timm/skills.git"
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "bun scripts/build.ts",
        "cli": "bun run src/cli.ts",
        "lint": "set -x; status=0; biome lint || status=$?; biome check || status=$?; eslint scripts src || status=$?; tsc --noEmit -p tsconfig.json || status=$?; exit $status",
        "pack": "bun pm pack --ignore-scripts --destination packs",
        "prepack": "bun run build",
        "prepublishOnly": "bun run lint && bun test && bun audit --audit-level=moderate",
        "release": "semantic-release",
        "release:preview": "semantic-release --dry-run --no-ci --plugins @semantic-release/commit-analyzer @semantic-release/release-notes-generator",
        "release:publish": "bun scripts/publish.ts"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.13",
        "@eslint/js": "^10.0.1",
        "@semantic-release/changelog": "^6.0.3",
        "@semantic-release/git": "^10.0.1",
        "@types/bun": "^1.3.12",
        "@types/node": "^25.6.0",
        "@types/pako": "^2.0.4",
        "@typescript-eslint/eslint-plugin": "^8.58.2",
        "@typescript-eslint/parser": "^8.58.2",
        "eslint": "^10.2.0",
        "eslint-plugin-simple-import-sort": "^13.0.0",
        "globals": "^17.5.0",
        "semantic-release": "^25.0.3",
        "typescript": "^6.0.2"
    },
    "dependencies": {
        "@andreas-timm/cli": "^0.1.3",
        "@andreas-timm/cli-table": "^0.1.1",
        "@andreas-timm/config": "^0.1.1",
        "@andreas-timm/logger": "^0.1.1",
        "@huggingface/transformers": "^4.1.0",
        "@iarna/toml": "^2.2.5",
        "cac": "^7.0.0",
        "date-fns": "^4.1.0",
        "fflate": "^0.8.2",
        "gray-matter": "^4.0.3",
        "pako": "^2.1.0",
        "rxjs": "^7.8.2",
        "string-width": "^8.2.0",
        "yaml": "^2.8.3",
        "zod": "^4.3.6"
    }
}
